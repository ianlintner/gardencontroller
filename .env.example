# Copy to .env and fill in. .env is gitignored — never commit real values.
# Single source of truth for board secrets and local curl/ingest testing.
#
#   cp .env.example .env
#   # edit .env
#   ./scripts/gen-arduino-secrets.sh   # writes firmware/garden-node/arduino_secrets.h

# WiFi the board joins
WIFI_SSID="your-ssid"
WIFI_PASS="your-wifi-password"

# OAuth2 client (client-credentials grant) registered in roauth2,
# audience = garden-ingest. One client per board so you can revoke individually.
OAUTH_CLIENT_ID="garden-node-1"
OAUTH_CLIENT_SECRET="replace-with-client-secret"

# Used only by scripts/verify.sh for the end-to-end curl test.
OAUTH_TOKEN_URL="https://roauth2.cat-herding.net/oauth/token"
OAUTH_AUDIENCE="garden-ingest"
INGEST_URL="https://garden.cat-herding.net/ingest"
