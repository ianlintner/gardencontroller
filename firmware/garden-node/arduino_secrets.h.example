// arduino_secrets.h.example — copy to arduino_secrets.h and fill in.
// arduino_secrets.h is gitignored; never commit real credentials.
#pragma once

// WiFi
#define SECRET_WIFI_SSID "your-ssid"
#define SECRET_WIFI_PASS "your-wifi-password"

// OAuth2 client-credentials client registered in roauth2 (audience garden-ingest).
// Each board should have its OWN client_id/secret so you can revoke one board.
#define SECRET_OAUTH_CLIENT_ID     "garden-node-1"
#define SECRET_OAUTH_CLIENT_SECRET "replace-with-client-secret"
